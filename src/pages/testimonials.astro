    name: "Nina Rodriguez",
    handle: "@ninarodriguez",
    role: "RevOps Manager",
    company: "SignalFlow",
    init: "NR",
    bg: "bg-amber-100",
    txt: "text-amber-700",
    border: "border-amber-200",
    metric: "$12 cost per meeting",
    metricLabel: "Down from $180",
  },
  {
    text: "The AI Reply Agent is the real differentiator. Other tools can find leads, but none of them handle the entire conversation from first touch to booked meeting like Typpout does.",
    detail: "I've used every social selling and outreach tool on the market. Most stop at sending the first message. Typpout's AI Reply Agent handles the back-and-forth: answering questions, addressing objections, sharing relevant case studies, and actually booking the meeting on your calendar. It responded to a prospect's 3 follow-up questions at 11 PM on a Saturday — something my human SDRs would never do. That meeting converted to a $25K deal.",
    name: "David Kim",
    handle: "@davidkim_sales",
    role: "CRO",
    company: "Pinnacle GTM",
    init: "DK",
    bg: "bg-emerald-100",
    txt: "text-emerald-700",
    border: "border-emerald-200",
    metric: "24/7 reply coverage",
    metricLabel: "AI handles nights & weekends",
  },
];

const stats = [
  { value: "47%", label: "Average reply rate" },
  { value: "20+", label: "Meetings booked per month" },
  { value: "8s", label: "Average AI reply time" },
  { value: "3-5x", label: "Meeting lift vs cold outbound" },
];

const testimonialsLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Testimonials", "item": `${SITE.url}/testimonials` },
  ],
};
---

<Layout
  title="Testimonials - What GTM Teams Say About Typpout"
  description="See how GTM teams use Typpout to book qualified meetings from social intent signals. Real results from real customers across SaaS, agencies, and enterprise sales."
  keywords={["Typpout reviews", "Typpout testimonials", "social selling results", "AI SDR results", "GTM platform reviews"]}
  jsonLd={testimonialsLd}
>
  <!-- Hero section -->
  <section class="mx-auto w-full max-w-[1280px] border-x border-b border-[color:var(--color-border)] bg-[color:var(--color-surface-muted)]">
    <div class="px-5 py-20 text-center sm:px-8 lg:py-24">
      <span class="eyebrow">Testimonials</span>
      <h1 class="h-section mt-4 text-balance">
        Real Results from
        <span class="text-[color:var(--color-brand)]">Real Teams</span>
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-[17px] leading-relaxed text-[color:var(--color-ink-secondary)]">
        Don't take our word for it. Here's what GTM teams, founders, and revenue leaders say about switching to signal-based social selling with Typpout.
      </p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="mx-auto w-full max-w-[1280px] border-x border-b border-[color:var(--color-border)]">
    <div class="grid grid-cols-2 lg:grid-cols-4">
      {stats.map((s, i) => (
        <div class:list={[
          "flex flex-col items-center gap-1 py-8 text-center",
          i < stats.length - 1 ? "border-r border-[color:var(--color-border)]" : "",
          i === 1 ? "max-lg:border-r-0 max-lg:border-b border-[color:var(--color-border)]" : "",
          i === 0 ? "max-lg:border-b border-[color:var(--color-border)]" : "",
        ]}>
          <span class="font-display text-2xl font-medium text-[color:var(--color-brand)] sm:text-3xl">{s.value}</span>
          <span class="text-sm text-[color:var(--color-ink-secondary)]">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Detailed testimonials -->
  <section class="mx-auto w-full max-w-[1280px] border-x border-[color:var(--color-border)]">
    <div class="px-4 py-20 md:px-10 md:py-28">
      <div class="space-y-8">
        {testimonials.map((t, i) => (
          <div
            class:list={[
              "group rounded-2xl border bg-white p-6 transition-all duration-300 hover:shadow-lg sm:p-8",
              t.border,
            ]}
            data-reveal
          >
            <div class="flex flex-col gap-6 lg:flex-row lg:gap-10">

              <!-- Left: Quote & Attribution -->
              <div class="flex-1 space-y-5">
                <!-- Star rating -->
                <div class="flex items-center gap-0.5">
                  {[1, 2, 3, 4, 5].map(() => (
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  ))}
                </div>

                <!-- Main quote -->
                <blockquote class="text-lg font-medium leading-relaxed text-[color:var(--color-ink-strong)] sm:text-xl">
                  "{t.text}"
                </blockquote>

                <!-- Detailed story -->
                <p class="text-[15px] leading-relaxed text-[color:var(--color-ink-secondary)]">
                  {t.detail}
                </p>

                <!-- Attribution -->
                <div class="flex items-center gap-3 pt-2">
                  <span class:list={["grid h-11 w-11 shrink-0 place-items-center rounded-full text-sm font-semibold", t.bg, t.txt]}>
                    {t.init}
                  </span>
                  <div>
                    <div class="text-[15px] font-semibold text-[color:var(--color-ink-strong)]">{t.name}</div>
                    <div class="text-[13px] text-[color:var(--color-ink-muted)]">{t.role}, {t.company}</div>
                  </div>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="ml-auto text-[color:var(--color-ink-subtle)]" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.738l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                </div>
              </div>

              <!-- Right: Key metric card -->
              <div class="flex items-start lg:w-56">
                <div class:list={[
                  "w-full rounded-xl border p-5 text-center transition-transform duration-300 group-hover:scale-105",
                  t.border, t.bg,
                ]}>
                  <div class:list={["font-display text-2xl font-medium sm:text-3xl", t.txt]}>
                    {t.metric}
                  </div>
                  <div class:list={["mt-1 text-[13px] font-medium", t.txt]}>
                    {t.metricLabel}
                  </div>
                </div>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA />
</Layout>
