---
import Layout from "../layouts/Layout.astro";
import FinalCTA from "../components/FinalCTA.astro";
import { SITE } from "../data/site";

const testimonials = [
  {
    text: "The social listening agent and AI reply agent are perfect for our GTM motions. They efficiently help us book 20+ meetings monthly without any manual prospecting.",
    detail: "Before Typpout, our team spent 4-5 hours daily on manual LinkedIn monitoring and cold outreach. The social listener now catches intent signals across LinkedIn, X, and Instagram in real-time. Our SDR team has been freed up to focus entirely on demos and closing. In Q1 alone, we booked 67 qualified meetings — all sourced from social intent signals.",
    name: "Santosh Patil",
    handle: "@santoshpatil",
    role: "CEO",
    company: "TechVista Solutions",
    init: "SP",
    bg: "bg-green-100",
    txt: "text-green-700",
    border: "border-green-200",
    metric: "20+ meetings/month",
    metricLabel: "Meetings booked monthly",
  },
  {
    text: "Typpout feels different — it's built for PMMs and GTM teams, not just sales. The ICP Finder alone saves me hours every week. I stopped using Apollo entirely.",
