    name: "Raiyaan Akhtar",
    handle: "@raiyaan_gtm",
    role: "GTM Lead",
    company: "Carpl.AI",
    init: "RA",
    bg: "bg-blue-100",
    txt: "text-blue-700",
    border: "border-blue-200",
    metric: "$800/mo saved",
