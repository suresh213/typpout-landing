---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BlogCard from "../../components/BlogCard.astro";
import FinalCTA from "../../components/FinalCTA.astro";
import { SITE } from "../../data/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

// Extract FAQ Q&A pairs from the raw markdown body for FAQPage schema
function parseFaqs(body: string): Array<{ question: string; answer: string }> {
  const marker = "## Frequently Asked Questions";
  const start = body.indexOf(marker);
  if (start === -1) return [];

  const afterHeader = body.slice(start + marker.length);
  const nextSection = afterHeader.search(/\n## /);
  const faqBlock = nextSection > -1 ? afterHeader.slice(0, nextSection) : afterHeader;

  const faqs: Array<{ question: string; answer: string }> = [];
  const re = /### (.+?)\n([\s\S]+?)(?=\n### |\s*$)/g;
  let m: RegExpExecArray | null;

  while ((m = re.exec(faqBlock)) !== null) {
    const question = m[1].trim();
    const answer = m[2]
      .trim()
      .replace(/\*\*(.+?)\*\*/g, "$1")
      .replace(/\*(.+?)\*/g, "$1")
      .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
      .replace(/`([^`]+)`/g, "$1")
      .replace(/\n+/g, " ")
      .trim();
    if (question && answer) faqs.push({ question, answer });
  }
  return faqs;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const all = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Smart related posts: same category gets +3, each shared tag gets +1, then by recency
const related = all
  .filter((p) => p.id !== post.id)
  .map((p) => {
    let score = 0;
    if (p.data.category === post.data.category) score += 3;
    score += p.data.tags.filter((t) => post.data.tags.includes(t)).length;
    return { p, score };
  })
  .sort((a, b) => b.score - a.score || b.p.data.pubDate.valueOf() - a.p.data.pubDate.valueOf())
  .slice(0, 3)
  .map(({ p }) => p);

const pubDate = post.data.pubDate;
const updated = post.data.updatedDate;

// Table of contents from H2 headings
const tocItems = headings.filter((h) => h.depth === 2);

// FAQ schema data
const faqs = parseFaqs(post.body ?? "");

// Build JSON-LD graph
const ldGraph: unknown[] = [
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${SITE.url}/blog` },
      { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `${SITE.url}/blog/${post.id}` },
    ],
  },
  {
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": pubDate.toISOString(),
    "dateModified": (updated ?? pubDate).toISOString(),
    "author": {
      "@type": "Person",
      "name": "Suresh",
      "jobTitle": "Founder",
      "worksFor": { "@type": "Organization", "name": SITE.name },
      "url": `https://x.com/${SITE.founder.handle.replace("@", "")}`,
    },
    "publisher": {
      "@type": "Organization",
      "name": SITE.name,
      "logo": { "@type": "ImageObject", "url": `${SITE.url}/logo-full.webp` },
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": `${SITE.url}/blog/${post.id}` },
    "keywords": post.data.tags.join(", "),
    "articleSection": post.data.category,
    "wordCount": (post.body ?? "").split(/\s+/).length,
  },
];

if (faqs.length > 0) {
  ldGraph.push({
    "@type": "FAQPage",
    "mainEntity": faqs.map(({ question, answer }) => ({
      "@type": "Question",
      "name": question,
      "acceptedAnswer": { "@type": "Answer", "text": answer },
    })),
  });
}

const articleLd = { "@context": "https://schema.org", "@graph": ldGraph };

const dateStr = pubDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
const updatedStr = updated?.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });

const accents = ["green", "blue", "pink", "yellow"] as const;
---

<Layout
  title={post.data.seoTitle ?? post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={(updated ?? pubDate).toISOString()}
  author={post.data.author}
  keywords={post.data.tags}
  image={`/og/${post.id}.png`}
  jsonLd={articleLd}
>
  <article>
    <!-- Hero -->
    <header class="mx-auto w-full max-w-[1280px] border-x border-b border-[color:var(--color-border)] bg-[color:var(--color-surface-muted)]">
      <div class="mx-auto w-full max-w-3xl px-5 py-16 text-center sm:px-8 lg:py-20">
        <div class="flex items-center justify-center gap-2 text-[13px] font-medium uppercase tracking-[0.14em] text-[color:var(--color-foreground-secondary)]">
          <a href="/blog" class="hover:text-[color:var(--color-foreground)]">{post.data.category}</a>
          {post.data.readingTime && (
            <>
              <span class="h-1 w-1 rounded-full bg-current opacity-60"></span>
              <span>{post.data.readingTime}</span>
            </>
          )}
        </div>
        <h1 class="mt-5 font-display text-balance text-4xl leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
          {post.data.title}
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-[17px] leading-relaxed text-[color:var(--color-foreground-secondary)]">
          {post.data.description}
        </p>
        <div class="mt-8 flex items-center justify-center gap-3.5 text-left">
          {post.data.author.toLowerCase().includes("suresh") ? (
            <img
              src="/Suresh_founder.webp"
              alt="Suresh, Founder of Typpout"
              class="h-12 w-12 rounded-full object-cover border border-stone-200/80 shadow-xs"
              width="48"
              height="48"
              loading="eager"
            />
          ) : (
            <span class="grid h-12 w-12 place-items-center rounded-full bg-[color:var(--color-foreground)] text-sm font-semibold uppercase text-[color:var(--color-brand)]">
              {post.data.author[0]}
            </span>
          )}
          <div class="flex flex-col">
            <span class="font-bold text-[16px] text-[color:var(--color-foreground)] leading-tight">Suresh</span>
            <span class="text-[13px] text-[color:var(--color-foreground-secondary)] mt-0.5">
              Founder, Typpout
              <span class="mx-1.5 text-stone-300">•</span>
              <time datetime={pubDate.toISOString()}>{dateStr}</time>
              {updatedStr && (
                <>
                  <span class="mx-1.5 text-stone-300">•</span>
                  <span>Updated {updatedStr}</span>
                </>
              )}
            </span>
          </div>
        </div>
      </div>
    </header>

    <!-- Body -->
    <div class="mx-auto grid w-full max-w-[1280px] border-x border-[color:var(--color-border)] grid-cols-1 gap-12 px-5 py-16 sm:px-8 lg:grid-cols-[1fr_280px] lg:gap-16 lg:py-24">
      <div class="prose-typpout">
        <Content />

        <!-- Tags -->
        {post.data.tags.length > 0 && (
          <div class="mt-12 flex flex-wrap gap-2 border-t border-[color:var(--color-border)] pt-8 not-prose">
            {post.data.tags.map((t) => (
              <span class="rounded-full bg-[color:var(--color-secondary)] px-3 py-1 text-[12px] font-medium text-[color:var(--color-foreground-secondary)]">
                #{t}
              </span>
            ))}
          </div>
        )}
      </div>

      <!-- Sticky sidebar -->
      <aside class="lg:sticky lg:top-24 lg:self-start space-y-5">

        <!-- Table of contents -->
        {tocItems.length >= 3 && (
          <nav class="rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface-muted)] p-5" aria-label="Table of contents">
            <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-[color:var(--color-foreground-secondary)]">Contents</p>
            <ul class="mt-3 space-y-2 list-none p-0">
              {tocItems.map((h) => (
                <li class="p-0 m-0 flex items-start gap-2 group">
                  <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-current opacity-40 transition-colors group-hover:bg-[color:var(--color-brand)] group-hover:opacity-100"></span>
                  <a
                    href={`#${h.slug}`}
                    class="text-[13px] leading-snug text-[color:var(--color-foreground-secondary)] hover:text-[color:var(--color-foreground)] hover:underline transition-colors cursor-pointer"
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )}

        <!-- CTA -->
        <div class="rounded-3xl border border-[color:var(--color-foreground)] bg-[color:var(--color-foreground)] p-6 text-white">
          <div class="text-[11px] uppercase tracking-[0.14em] text-white/60">Get Typpout</div>
          <h3 class="mt-2 font-display text-2xl leading-tight">
            Turn social conversations into booked meetings.
          </h3>
          <p class="mt-3 text-[13px] text-white/70">
            Start a 3-day free trial. No credit card required.
          </p>
          <a href={SITE.appUrl} class="mt-5 flex h-11 w-full items-center justify-center rounded-xl bg-[color:var(--color-brand)] text-[14px] font-medium text-white transition-colors hover:bg-[color:var(--color-brand-strong)]">
            Get started - it's free
          </a>
        </div>

        <!-- Share -->
        <div class="rounded-2xl border border-[color:var(--color-border)] bg-white p-5">
          <div class="text-[11px] uppercase tracking-[0.14em] text-[color:var(--color-foreground-secondary)]">Share</div>
          <div class="mt-3 flex gap-2">
            <button
              data-share="copy"
              class="grid h-9 w-9 place-items-center rounded-lg border border-[color:var(--color-border)] bg-white text-[color:var(--color-foreground-secondary)] transition-all duration-200 hover:text-[color:var(--color-foreground)]"
              aria-label="Copy link"
            >
              <svg class="copy-icon h-3.5 w-3.5 animate-fade-in" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="9" y="9" width="10" height="10" rx="2" stroke="currentColor" stroke-width="2"/>
                <path d="M5 15V5a2 2 0 012-2h10" stroke="currentColor" stroke-width="2"/>
              </svg>
              <svg class="check-icon hidden h-3.5 w-3.5 text-green-600 animate-fade-in" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </button>
            <a
              data-share="x"
              class="grid h-9 w-9 place-items-center rounded-lg border border-[color:var(--color-border)] bg-white transition-all duration-200 hover:border-[color:var(--color-brand)]/40 hover:bg-[color:var(--color-brand-50)] hover:scale-105"
              aria-label="Share on X"
              target="_blank"
              rel="noopener noreferrer"
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`${SITE.url}/blog/${post.id}`)}`}
            >
              <img src="/logos/x.webp" alt="X Logo" width="14" height="14" class="h-3.5 w-3.5 object-contain rounded-xs" />
            </a>
            <a
              class="grid h-9 w-9 place-items-center rounded-lg border border-[color:var(--color-border)] bg-white transition-all duration-200 hover:border-[color:var(--color-brand)]/40 hover:bg-[color:var(--color-brand-50)] hover:scale-105"
              aria-label="Share on LinkedIn"
              target="_blank"
              rel="noopener noreferrer"
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`${SITE.url}/blog/${post.id}`)}`}
            >
              <img src="/logos/linkedin.webp" alt="LinkedIn Logo" width="14" height="14" class="h-3.5 w-3.5 object-contain rounded-xs" />
            </a>
          </div>
        </div>
      </aside>
    </div>
  </article>

  {related.length > 0 && (
    <section class="mx-auto w-full max-w-[1280px] border-x border-t border-[color:var(--color-border)] bg-[color:var(--color-surface-muted)]">
      <div class="px-5 py-16 sm:px-8 lg:py-24">
        <h2 class="h-section mb-10">Keep reading</h2>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {related.map((p, i) => (
            <BlogCard
              href={`/blog/${p.id}`}
              title={p.data.title}
              description={p.data.description}
              pubDate={p.data.pubDate}
              category={p.data.category}
              readingTime={p.data.readingTime}
              accent={accents[i % accents.length]}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <FinalCTA />
</Layout>

<script>
  const copyBtn = document.querySelector('[data-share="copy"]');
  const copyIcon = copyBtn?.querySelector('.copy-icon');
  const checkIcon = copyBtn?.querySelector('.check-icon');

  copyBtn?.addEventListener("click", async () => {
    const text = window.location.href;
    let success = false;
    try {
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
        success = true;
      } else {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.focus();
        textArea.select();
        success = document.execCommand("copy");
        document.body.removeChild(textArea);
      }
    } catch (_) {
      success = false;
    }

    if (success) {
      copyBtn.setAttribute("aria-label", "Copied!");
      copyIcon?.classList.add("hidden");
      checkIcon?.classList.remove("hidden");
      copyBtn.classList.add("border-green-300", "bg-green-50/50");

      setTimeout(() => {
        copyBtn.setAttribute("aria-label", "Copy link");
        copyIcon?.classList.remove("hidden");
        checkIcon?.classList.add("hidden");
        copyBtn.classList.remove("border-green-300", "bg-green-50/50");
      }, 1500);
    }
  });
</script>
