---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import LogoMarquee from "../components/LogoMarquee.astro";
import WhyTyppout from "../components/WhyTyppout.astro";
import DarkAgents from "../components/DarkAgents.astro";
import Stats from "../components/Stats.astro";
import ProductStack from "../components/ProductStack.astro";
import Testimonials from "../components/Testimonials.astro";
import FAQ from "../components/FAQ.astro";
import FinalCTA from "../components/FinalCTA.astro";
import { SITE } from "../data/site";

const productLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": SITE.name,
      "url": SITE.url,
      "logo": { "@type": "ImageObject", "url": `${SITE.url}/logo-full.webp` },
      "sameAs": [
        "https://x.com/typpout",
        "https://linkedin.com/company/typpout",
        "https://youtube.com/@typpout",
        "https://instagram.com/typpout",
      ],
      "description": SITE.description,
      "foundingDate": "2025",
      "founder": {
        "@type": "Person",
        "name": "Suresh",
        "url": `https://x.com/${SITE.founder.handle.replace("@", "")}`,
      },
    },
    {
      "@type": "WebSite",
      "url": SITE.url,
      "name": SITE.name,
      "description": SITE.description,
      "publisher": { "@type": "Organization", "name": SITE.name },
    },
    {
      "@type": "SoftwareApplication",
      "name": "Typpout",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": SITE.description,
      "brand": { "@type": "Brand", "name": SITE.name },
      "url": SITE.url,
      "image": `${SITE.url}/logo-full.webp`,
      "offers": [
        { "@type": "Offer", "name": "Solo", "price": "99",  "priceCurrency": "USD", "url": `${SITE.url}/pricing` },
        { "@type": "Offer", "name": "Growth", "price": "249", "priceCurrency": "USD", "url": `${SITE.url}/pricing` },
        { "@type": "Offer", "name": "Done For You", "price": "990", "priceCurrency": "USD", "url": `${SITE.url}/pricing` },
      ],
    },
  ],
};
---

<Layout
  title="AI Go-To-Market Platform for Social Selling & Intent Signals"
  description="Typpout is the AI GTM platform that listens to social signals on LinkedIn, X and Instagram, matches leads to your ICP, and books meetings on autopilot."
  jsonLd={productLd}
>
  <Hero />
  <LogoMarquee />
  <WhyTyppout />
  <DarkAgents />
  <Stats />
  <ProductStack />
  <Testimonials />
  <FAQ />
  <FinalCTA />
</Layout>
