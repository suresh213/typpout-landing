const integrationsLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": SITE.url
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Integrations",
          "item": `${SITE.url}/integrations`
        }
      ]
    },
    {
      "@type": "WebPage",
      "name": "Typpout Integrations",
      "description": "Explore Typpout's native integrations across CRMs, Social Selling channels, Lead enrichment systems, and Email outreach workflows.",
      "url": `${SITE.url}/integrations`,
    }
