---
const features = [
  {
    eyebrow: "01 · Social Listening Agent",
    title: "Hear every buying signal across LinkedIn, X and Instagram",
    body: "Track real-time conversations, comments, reactions and posts. Typpout surfaces the moments when your buyers are showing intent - and lets you act before anyone else.",
    palette: "green",
    visual: "listening" as const,
  },
  {
    eyebrow: "02 · ICP Finder Agent",
    title: "Stop wasting hours on leads who'll never buy",
    body: "Typpout matches signals to your exact ICP - title, geography, company size, tech stack and budget - so every outreach lands with someone already in-market.",
    palette: "blue",
    visual: "icp" as const,
  },
  {
    eyebrow: "03 · Personalised Outreach Agent",
    title: "Messages that feel human - not 'AI-generated'",
    body: "Generate context-aware DMs and comments that reference the prospect's own post, role, and stage. Reply rates that beat hand-written outreach.",
    palette: "pink",
    visual: "outreach" as const,
  },
  {
    eyebrow: "04 · AI Reply Agent",
    title: "Never lose a hot lead to a slow reply",
    body: "Typpout responds to every prospect within seconds - with the full context of their original signal. Book the meeting before they forget you exist.",
    palette: "yellow",
    visual: "reply" as const,
  },
];

const palettes = {
  green: { bg: "var(--color-pastel-green)", border: "var(--color-pastel-green-border)", fg: "var(--color-pastel-green-fg)" },
  blue: { bg: "var(--color-pastel-blue)", border: "var(--color-pastel-blue-border)", fg: "var(--color-pastel-blue-fg)" },
  pink: { bg: "var(--color-pastel-pink)", border: "var(--color-pastel-pink-border)", fg: "var(--color-pastel-pink-fg)" },
  yellow: { bg: "var(--color-pastel-yellow)", border: "var(--color-pastel-yellow-border)", fg: "var(--color-pastel-yellow-fg)" },
} as const;
---

<section id="features" class="relative">
  <div class="mx-auto w-full max-w-[1280px] px-5 py-24 sm:px-8 lg:py-32">
    <div class="max-w-3xl" data-reveal>
      <span class="eyebrow">The Typpout AI agents</span>
      <h2 class="h-section mt-4">
        Four agents.
        <span class="font-display-italic text-[color:var(--color-foreground-secondary)]">One unfair pipeline.</span>
      </h2>
      <p class="mt-5 max-w-2xl text-[17px] leading-relaxed text-[color:var(--color-foreground-secondary)]">
        Replace your sales-engagement stack, manual prospecting, and reply-checking workflows with four AI agents working in sync - 24/7.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-2">
      {features.map((f, i) => {
        const p = palettes[f.palette];
        return (
          <article
            class="relative flex flex-col gap-6 overflow-hidden rounded-3xl border p-7 transition"
            style={`background:${p.bg}; border-color:${p.border}; color:${p.fg};`}
            data-reveal
          >
            <div class="flex items-start justify-between gap-4">
              <span class="text-[12px] font-medium uppercase tracking-[0.14em]">{f.eyebrow}</span>
              <span class="grid h-9 w-9 place-items-center rounded-full bg-white/70 backdrop-blur" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>

            <h3 class="h-card text-balance text-[24px] leading-[1.2] sm:text-[28px]" style={`color:${p.fg}`}>
              {f.title}
            </h3>

            <p class="text-[15px] leading-relaxed" style={`color:color-mix(in oklab, ${p.fg} 80%, transparent)`}>
              {f.body}
            </p>

            <!-- Visual block -->
            <div class="mt-2 rounded-2xl border bg-white/70 p-4 backdrop-blur" style={`border-color:${p.border}`}>
              {f.visual === "listening" && (
                <div class="space-y-2 text-[13px]">
                  {[
                    "@arjun: 'cold email is dead, what are people using?'",
                    "@maya: 'evaluating outbound tools for Q3'",
                    "@priya: 'looking for an SDR tool for PMM teams'",
                  ].map((s) => (
                    <div class="flex items-center gap-2 rounded-md border border-dashed border-[color:var(--color-border)] bg-white px-2 py-1.5">
                      <span class="h-1.5 w-1.5 rounded-full bg-current" aria-hidden="true"></span>
                      <span class="truncate text-[color:var(--color-foreground)]">{s}</span>
                    </div>
                  ))}
                </div>
              )}
              {f.visual === "icp" && (
                <div class="grid grid-cols-2 gap-2 text-[12px]">
                  {[
                    { k: "Title", v: "Head of Growth" },
                    { k: "Company", v: "Series A SaaS" },
                    { k: "Geo", v: "NA + EU" },
                    { k: "Signal", v: "tool-evaluation post" },
                  ].map((row) => (
                    <div class="rounded-md bg-white px-3 py-2 text-[color:var(--color-foreground)]">
                      <div class="text-[10px] uppercase tracking-[0.14em] text-[color:var(--color-foreground-secondary)]">{row.k}</div>
                      <div class="text-[13px] font-medium">{row.v}</div>
                    </div>
                  ))}
                </div>
              )}
              {f.visual === "outreach" && (
                <div class="space-y-2 text-[13px]">
                  <p class="rounded-md bg-white px-3 py-2 text-[color:var(--color-foreground)]">
                    "Saw your post on cold-email fatigue - we hit the same wall at Pulse. Worth a 10‑min loom?"
                  </p>
                  <div class="flex items-center justify-between text-[11px]">
                    <span>Tone · Friendly</span>
                    <span class="font-medium">Replied in 0:00:08</span>
                  </div>
                </div>
              )}
              {f.visual === "reply" && (
                <div class="space-y-2 text-[13px]">
                  <div class="rounded-md bg-white px-3 py-2 text-[color:var(--color-foreground)]">
                    Lead: "Sounds interesting - what's the price?"
                  </div>
                  <div class="rounded-md bg-[color:var(--color-foreground)] px-3 py-2 text-white">
                    Typpout: "Plans start at $99/mo · I can show you live on a 15‑min call. Pick a time?"
                  </div>
                </div>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
