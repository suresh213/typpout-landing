---
---

<section class="mx-auto w-full max-w-[1280px] border-x border-[color:var(--color-border)]">

  <!-- Pain section - left text + right stacked pills (matches template layout exactly) -->
  <div class="overflow-x-clip bg-secondary flex flex-col items-start justify-between border-b border-[color:var(--color-border)] py-20 md:py-28 lg:flex-row lg:items-center">
    <div class="p-4 md:p-12" data-reveal>
      <h2 class="font-display text-2xl font-medium sm:text-3xl lg:text-[40px] leading-tight tracking-tight text-[color:var(--color-ink)]">
        You're running a go-to-market team.
      </h2>
      <h2 class="font-display mt-2 max-w-lg text-2xl font-medium sm:text-3xl lg:text-[40px] leading-tight tracking-tight text-[color:var(--color-ink-secondary)] opacity-50">
        Why are you still prospecting manually?
      </h2>
      <p class="mt-6 max-w-lg text-base font-light leading-relaxed text-[color:var(--color-ink-secondary)]">
        List-building, signal monitoring, personalised messaging, follow-ups, none of this should eat your team's time. Typpout gives you four AI agents that handle every step of outbound, from first signal to booked meeting.
      </p>
    </div>

    <div class="ml-auto flex w-full flex-col gap-5 pl-6 sm:w-1/3 sm:max-w-xl sm:pl-0" data-reveal>
      {[
        { label: "Social Listening", iconBg: "bg-emerald-50 border-emerald-100/60 text-emerald-600 group-hover:bg-emerald-100 group-hover:border-emerald-200", icon: "radar" },
        { label: "ICP Finder",       iconBg: "bg-blue-50 border-blue-100/60 text-blue-600 group-hover:bg-blue-100 group-hover:border-blue-200",    icon: "users" },
        { label: "AI Outreach",      iconBg: "bg-purple-50 border-purple-100/60 text-purple-600 group-hover:bg-purple-100 group-hover:border-purple-200", icon: "message" },
        { label: "AI Reply Agent",   iconBg: "bg-orange-50 border-orange-100/60 text-orange-600 group-hover:bg-orange-100 group-hover:border-orange-200", icon: "bolt" },
      ].map((f) => (
        <div class="slide-in-left flex w-full items-center gap-4 rounded-l-2xl border border-r-0 border-stone-200/80 bg-white py-4 pl-6 pr-6 text-stone-800 shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] transition-all duration-300 hover:bg-stone-50/50 hover:translate-x-[-8px] hover:shadow-md cursor-pointer group">
          <div class:list={["flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border transition-all duration-200", f.iconBg]}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="shrink-0" aria-hidden="true">
              {f.icon === "radar"   && <><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="7" stroke="currentColor" stroke-width="2"/><path d="M12 5v-2M12 21v-2" stroke="currentColor" stroke-width="2"/></>}
              {f.icon === "users"   && <><circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="2"/><path d="M3 20c0-3 3-5 6-5s6 2 6 5M16 11a3 3 0 100-6M21 20c0-2.5-2-4-4.5-4.5" stroke="currentColor" stroke-width="2"/></>}
              {f.icon === "message" && <path d="M4 6a2 2 0 012-2h12a2 2 0 012 2v9a2 2 0 01-2 2H9l-5 4V6z" stroke="currentColor" stroke-width="2"/>}
              {f.icon === "bolt"    && <path d="M13 2L4 14h7l-2 8 10-12h-7l1-8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>}
            </svg>
          </div>
          <span class="font-display text-[17px] font-semibold text-stone-700 tracking-tight transition-colors group-hover:text-stone-900">{f.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Everything You Need - 2×2 feature grid (matches template "Everything You Need to Monetise") -->
  <div class="flex flex-col gap-20 px-4 py-20 md:px-10 md:py-28">
    <div class="mx-auto max-w-xl space-y-4 text-center" data-reveal>
      <h2 class="font-display text-2xl font-medium sm:text-3xl lg:text-[40px] tracking-tight">
        Everything You Need to Turn<br class="hidden md:block" /> Social Conversations into Revenue
      </h2>
      <p class="text-base font-light text-[color:var(--color-ink-secondary)]">
        The all-in-one engine to find, engage, and convert social conversations into pipeline. Designed for the new generation of GTM teams.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {[
        {
          title: "Social Signal Detection",
          desc: "Monitor LinkedIn, X and Instagram for buying intent keywords, competitor mentions, job postings, and funding announcements, all matched to your ICP in real time.",
          previewType: "signals",
          preview: [
            { platform: "linkedin", text: "anyone using social listening for B2B? cold email is dead", iconBg: "bg-[#0A66C2]", label: "in" },
            { platform: "x", text: "moving off Apollo, looking for something signal-first", iconBg: "bg-black", label: "𝕏" },
            { platform: "reddit", text: "evaluating AI SDR tools this week", iconBg: "bg-[#FF4500]", label: "r/" }
          ]
        },
        {
          title: "ICP Finder & Enrichment",
          desc: "Every signal is automatically matched against your ideal customer profile. Get enriched contact data, firmographics, and a fit score so you always know who to reach first.",
          previewType: "icp",
          preview: [
            { name: "Sarah Kim", title: "VP Sales · Growthbase", score: "97%", init: "SK", scoreColor: "text-emerald-600 bg-emerald-50 border-emerald-100/50" },
            { name: "Marcus Webb", title: "Head of Revenue · Synthos", score: "93%", init: "MW", scoreColor: "text-blue-600 bg-blue-50 border-blue-100/50" },
            { name: "Priya Shah", title: "PMM · Northbeam", score: "91%", init: "PS", scoreColor: "text-purple-600 bg-purple-50 border-purple-100/50" }
          ]
        },
        {
          title: "Personalised AI Outreach",
          desc: "Stop sending templates. Typpout drafts personalised first messages grounded in the exact social signal that triggered the match, sent at the right moment, automatically.",
          previewType: "outreach",
          preview: [
            { sender: "prospect", text: "outbound email is dead in 2026..." },
            { sender: "ai", text: "Saw your post Maya, built Typpout for this. 5-min call?" }
          ]
        },
        {
          title: "AI Reply Agent",
          desc: "Typpout replies to responses in under 8 seconds, handles objections, nurtures the conversation, and books a meeting on your calendar, without your team lifting a finger.",
          previewType: "reply",
          preview: [
            { status: "success", text: "Meeting booked ✓ Wed 3:30 PM", desc: "replied in 8s" },
            { status: "info", text: "Handled objection · Follow-up sent", desc: "objection: pricing" }
          ]
        }
      ].map((f, i) => {
        const delays = ["", "delay-100", "delay-200", "delay-300"];
        return (
          <div
            class:list={[
              "bg-secondary flex flex-col justify-between gap-8 overflow-hidden rounded-3xl p-8 shadow-[0_0_1px_1px_rgba(0,0,0,0.04)] hover:-translate-y-1 hover:shadow-md transition-all duration-300",
              delays[i]
            ]}
            data-reveal
          >
            <div class="flex flex-col gap-2">
              <h3 class="font-display text-base font-medium sm:text-lg lg:text-xl tracking-tight text-stone-800">{f.title}</h3>
              <p class="text-sm font-light text-[color:var(--color-ink-secondary)] leading-relaxed">{f.desc}</p>
            </div>
            
            <!-- preview container with grid background and a floating white card panel inside -->
            <div class="grid-bg rounded-2xl p-5 border border-stone-200/40" style="--grid-color:#f6f5f3;--grid-line-color:#e7e5e4;--grid-bg-opacity:100%;--grid-line-opacity:100%;--grid-size:14px">
              <div class="rounded-xl border border-stone-200/85 bg-white p-4 shadow-sm space-y-2.5">
                
                {f.previewType === "signals" && f.preview.map((row) => (
                  <div class="flex items-center gap-2.5 rounded-lg border border-stone-100 bg-stone-50/50 px-3 py-2 text-[12px] text-stone-700">
                    <span class="grid h-5 w-5 shrink-0 place-items-center rounded-full text-[9px] font-semibold text-white" style={`background:${row.iconBg}`}>{row.label}</span>
                    <span class="truncate font-medium text-stone-800">{row.text}</span>
                  </div>
                ))}

                {f.previewType === "icp" && f.preview.map((row) => (
                  <div class="flex items-center justify-between gap-3 rounded-lg border border-stone-100 bg-stone-50/50 px-3 py-2 text-[12px] text-stone-750">
                    <div class="flex items-center gap-2">
                      <span class="grid h-6 w-6 shrink-0 place-items-center rounded-full bg-stone-100 text-[10px] font-semibold text-stone-600 border border-stone-200/60">{row.init}</span>
                      <div class="min-w-0">
                        <div class="font-semibold text-stone-800 leading-none">{row.name}</div>
                        <div class="text-[10px] text-stone-500 mt-1 leading-none">{row.title}</div>
                      </div>
                    </div>
                    <span class:list={["font-mono text-[11px] font-bold px-1.5 py-0.5 rounded border border-stone-200 bg-white shrink-0", row.scoreColor]}>{row.score}</span>
                  </div>
                ))}

                {f.previewType === "outreach" && f.preview.map((row) => (
                  row.sender === "prospect" ? (
                    <div class="flex items-start gap-2 max-w-[90%]">
                      <span class="grid h-5 w-5 shrink-0 place-items-center rounded-full bg-stone-100 text-[10px] font-semibold text-stone-600 border border-stone-200">P</span>
                      <div class="rounded-xl rounded-tl-none border border-stone-200 bg-stone-50/50 px-3 py-2 text-[11px] text-stone-700 leading-relaxed">
                        {row.text}
                      </div>
                    </div>
                  ) : (
                    <div class="flex items-start gap-2 justify-end">
                      <div class="rounded-xl rounded-tr-none bg-[color:var(--color-brand)] px-3 py-2 text-[11px] text-white leading-relaxed max-w-[90%] shadow-2xs">
                        {row.text}
                      </div>
                      <span class="grid h-5 w-5 shrink-0 place-items-center rounded-full bg-[color:var(--color-brand-100)] text-[9px] font-semibold text-[color:var(--color-brand-on-light)] border border-[color:var(--color-brand-200)]">AI</span>
                    </div>
                  )
                ))}

                {f.previewType === "reply" && f.preview.map((row) => (
                  <div class:list={[
                    "flex items-center justify-between gap-3 rounded-lg border px-3.5 py-2 text-[12px] shadow-3xs",
                    row.status === "success" 
                      ? "bg-emerald-50/40 border-emerald-250 text-emerald-800" 
                      : "bg-white border-stone-200 text-stone-700"
                  ]}>
                    <div class="flex items-center gap-2">
                      <span class:list={[
                        "h-1.5 w-1.5 rounded-full",
                        row.status === "success" ? "bg-emerald-500 animate-pulse" : "bg-blue-500"
                      ]}></span>
                      <span class="font-semibold">{row.text}</span>
                    </div>
                    <span class="font-mono text-[10px] opacity-75">{row.desc}</span>
                  </div>
                ))}
                
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>

</section>
