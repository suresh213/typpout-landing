---
import { FOOTER_NAV, SOCIAL, SITE } from "../data/site";
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---

<footer class="border-t border-[color:var(--color-border)]">
  <div class="mx-auto w-full max-w-[1280px] border-x border-[color:var(--color-border)]">

    <!-- Main footer grid -->
    <div class="grid grid-cols-1 gap-12 border-b border-[color:var(--color-border)] px-6 py-14 md:px-10 md:py-16 lg:grid-cols-[2fr_1fr_1fr_1fr_1fr]">

      <!-- Brand column -->
      <div class="flex flex-col gap-5">
        <Logo />
        <p class="max-w-[260px] text-[14px] leading-relaxed text-[color:var(--color-ink-secondary)]">
          The AI go-to-market platform. Listen to socials, find in-market buyers, and book meetings on autopilot.
        </p>
        <div class="flex flex-wrap gap-2">
          {SOCIAL.map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              rel="noopener noreferrer"
              target="_blank"
              class="grid h-8 w-8 place-items-center rounded-lg border border-[color:var(--color-border)] bg-white transition-all duration-200 hover:border-[color:var(--color-brand)]/40 hover:bg-[color:var(--color-brand-50)] hover:scale-105"
            >
              <img
                src={`/logos/${s.icon}.webp`}
                alt={s.label}
                width="16"
                height="16"
                class="h-4 w-4 object-contain rounded-sm"
                loading="lazy"
              />
            </a>
          ))}
        </div>
      </div>

      <!-- Nav columns -->
      {Object.entries(FOOTER_NAV).map(([heading, links]) => (
        <div>
          <div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[color:var(--color-ink-muted)]">{heading}</div>
          <ul class="mt-4 space-y-2.5">
            {links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-[14px] text-[color:var(--color-ink-secondary)] transition-colors hover:text-[color:var(--color-ink)]"
                >
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col items-start justify-between gap-3 px-6 py-5 md:flex-row md:items-center md:px-10">
      <p class="text-[13px] text-[color:var(--color-ink-muted)]">
        {year} Typpout. All rights reserved.
      </p>
      <div class="flex items-center gap-1.5">
        <span class="h-1.5 w-1.5 rounded-full bg-[color:var(--color-brand)]"></span>
        <p class="text-[13px] text-[color:var(--color-ink-muted)]">
          Built for GTM teams who want pipeline.
        </p>
      </div>
    </div>
  </div>
</footer>
