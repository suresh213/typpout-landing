---
import { NAV, SITE } from "../data/site";
import Logo from "./Logo.astro";
const path = Astro.url.pathname;
---

<header
  id="site-header"
  class="sticky top-0 z-50 w-full border-b border-[color:var(--color-border)] bg-white/95 backdrop-blur-sm transition-shadow duration-200"
>
  <div class="mx-auto flex h-[60px] w-full max-w-[1280px] items-center justify-between px-5 sm:px-8">
    <Logo loading="eager" />

    <ul class="pointer-events-auto absolute left-1/2 hidden -translate-x-1/2 items-center gap-0.5 lg:flex">
      {NAV.map((item) => {
        const active = item.href.startsWith("/") && !item.href.includes("#")
          ? path === item.href || path.startsWith(item.href + "/")
          : path === "/" && item.href.startsWith("/#");
        return (
          <li>
            <a
              href={item.href}
              class:list={[
                "rounded-md px-3.5 py-2 text-[14px] font-medium transition-colors",
                active
                  ? "text-[color:var(--color-ink-strong)] bg-[color:var(--color-surface-soft)]"
                  : "text-[color:var(--color-ink-secondary)] hover:text-[color:var(--color-ink-strong)]",
              ]}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>

    <div class="hidden items-center gap-2.5 lg:flex">
      <a href={SITE.demoUrl} class="btn btn-sm btn-ghost">Book a Demo</a>
      <a href={SITE.appUrl} class="btn btn-sm bg-[color:var(--color-brand)] text-white hover:bg-[color:var(--color-brand-strong)] border-0 shadow-[0_2px_8px_rgba(124,90,197,0.2)]">Get started</a>
    </div>

    <button
      id="menu-toggle"
      class="grid h-9 w-9 place-items-center rounded-md border border-[color:var(--color-border)] text-[color:var(--color-ink-strong)] lg:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden">
    <div class="border-t border-[color:var(--color-border)] bg-white px-5 py-3 sm:px-8">
      <ul class="flex flex-col">
        {NAV.map((item) => (
          <li>
            <a
              href={item.href}
              class="block rounded-md px-3 py-2.5 text-[15px] font-medium text-[color:var(--color-ink-strong)] hover:bg-[color:var(--color-surface-soft)]"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-3 grid grid-cols-2 gap-2 border-t border-[color:var(--color-border)] pt-3">
        <a href={SITE.demoUrl} class="btn btn-ghost w-full justify-center">Book a Demo</a>
        <a href={SITE.appUrl} class="btn w-full justify-center bg-[color:var(--color-brand)] text-white hover:bg-[color:var(--color-brand-strong)]">Get started</a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(open));
  });

  menu?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("a")) {
      menu.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    }
  });

  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (!header) return;
    header.classList.toggle("is-scrolled", window.scrollY > 8);
    header.style.boxShadow = window.scrollY > 8
      ? "0 1px 0 rgba(0,0,0,0.06), 0 8px 24px -12px rgba(0,0,0,0.06)"
      : "";
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
