---
import { Image } from "astro:assets";
import logoImage from "../assets/logo.webp";

interface Props {
  class?: string;
  size?: "sm" | "md" | "lg";
  withMark?: boolean;
  loading?: "eager" | "lazy";
}
const { class: className = "", size = "md", withMark = true, loading = "lazy" } = Astro.props;

const dims = {
  sm: { mark: "h-7 w-7", text: "text-[18px]" },
  md: { mark: "h-8 w-8", text: "text-[20px]" },
  lg: { mark: "h-10 w-10", text: "text-[26px]" },
}[size];
---

<a href="/" aria-label="Typpout home" class={`group inline-flex items-center gap-2.5 ${className}`}>
  {withMark && (
    <Image
      src={logoImage}
      alt="Typpout Logo"
      width={40}
      height={40}
      class={`${dims.mark} rounded-[8px] object-contain`}
      loading={loading}
    />
  )}
  <span class={`font-display ${dims.text} font-medium tracking-[-0.03em] text-[color:var(--color-ink-strong)]`}>
    Typpout
  </span>
</a>
