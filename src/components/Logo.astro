---
interface Props {
  class?: string;
  size?: "sm" | "md" | "lg";
  loading?: "eager" | "lazy";
}
const { class: className = "", size = "md", loading = "lazy" } = Astro.props;

const dims = {
  sm: { height: 28, width: 104, class: "h-7 w-[104px]" },
  md: { height: 32, width: 120, class: "h-8 w-[120px]" },
  lg: { height: 40, width: 150, class: "h-10 w-[150px]" },
}[size];
---

<a href="/" aria-label="Typpout home" class={`group inline-flex items-center ${className}`}>
  <img
    src="/logo-full.webp"
    alt="Typpout Logo"
    width={dims.width}
    height={dims.height}
    class={`${dims.class} object-contain`}
    loading={loading}
  />
</a>
