---
import { SITE } from "../data/site";
---

<section id="features" class="mx-auto w-full max-w-[1280px] border-x border-[color:var(--color-border)]">
  <div class="flex flex-col gap-20 border-b border-[color:var(--color-border)] px-4 py-20 md:px-10 md:py-28">

    <div class="space-y-4 text-center" data-reveal>
      <h2 class="font-display text-2xl font-medium sm:text-3xl lg:text-[40px] tracking-tight">
        The Metrics That Matter
      </h2>
      <p class="mx-auto max-w-lg text-base font-light text-[color:var(--color-ink-secondary)]">
        From signal detection to booked meetings, every step measured. Here's how Typpout impacts your GTM pipeline.
      </p>
    </div>

    <!-- Big metric cards - row 1 -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4" data-reveal>
      {[
        {
          stat: "1,284",
          unit: "/day",
          label: "Signals Monitored",
          description: "Buying intent signals detected daily across LinkedIn, X, and Instagram",
          icon: "radar",
          color: "text-green-600",
          bg: "bg-green-50",
          border: "border-green-200",
          line: "#58A786",
          gridBg: "#e9f7f0",
        },
        {
          stat: "47",
          unit: "%",
          label: "Reply Rate",
          description: "Average reply rate on signal-matched outreach vs 1-5% for cold email",
          icon: "reply",
          color: "text-blue-600",
          bg: "bg-blue-50",
          border: "border-blue-200",
          line: "#6082D2",
          gridBg: "#e7efff",
        },
        {
          stat: "25",
          unit: "+",
          label: "Meetings / Month",
          description: "Qualified meetings booked monthly from warm social intent signals",
          icon: "calendar",
          color: "text-purple-600",
          bg: "bg-purple-50",
          border: "border-purple-200",
          line: "#786EC8",
          gridBg: "#f2eefe",
        },
        {
          stat: "8",
          unit: "s",
          label: "AI Reply Time",
          description: "Average time for AI Reply Agent to respond with a personalised message",
          icon: "bolt",
          color: "text-orange-600",
          bg: "bg-orange-50",
          border: "border-orange-200",
          line: "#C8823C",
          gridBg: "#fff7ed",
        },
      ].map((m) => (
        <div
          class="grid-bg group rounded-2xl border border-[color:var(--color-border)] p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
          style={`--grid-color:${m.gridBg};--grid-line-color:${m.line};--grid-bg-opacity:100%;--grid-line-opacity:3%;--grid-size:14px`}
        >
          <div class:list={["mb-4 flex h-10 w-10 items-center justify-center rounded-xl", m.bg]}>
            {m.icon === "radar" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class={m.color}>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
                <circle cx="12" cy="12" r="7" stroke="currentColor" stroke-width="2"/>
                <path d="M12 5v-2M12 21v-2" stroke="currentColor" stroke-width="2"/>
              </svg>
            )}
            {m.icon === "reply" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={m.color}>
                <polyline points="9 17 4 12 9 7"/><path d="M20 18v-2a4 4 0 00-4-4H4"/>
              </svg>
            )}
            {m.icon === "calendar" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={m.color}>
                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/>
              </svg>
            )}
            {m.icon === "bolt" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class={m.color}>
                <path d="M13 2L4 14h7l-2 8 10-12h-7l1-8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
          <div class="flex items-baseline gap-1">
            <span class:list={["font-display text-3xl font-medium tracking-tight sm:text-4xl", m.color]} data-countup-target={`${m.stat}${m.unit}`}>{m.stat}{m.unit}</span>
          </div>
          <div class="mt-1 text-sm font-semibold text-[color:var(--color-ink-strong)]">{m.label}</div>
          <p class="mt-2 text-[13px] leading-relaxed text-[color:var(--color-ink-secondary)]">{m.description}</p>
        </div>
      ))}
    </div>

    <!-- Detailed metric rows -->
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3" data-reveal>

      <!-- Prospects Surfaced -->
      <div class="rounded-2xl border border-[color:var(--color-border)] bg-white p-6 transition-all duration-300 hover:shadow-md">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-teal-50">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-teal-600">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-[color:var(--color-ink-strong)]">Prospects Surfaced</div>
            <div class="text-[12px] text-[color:var(--color-ink-muted)]">ICP-matched leads found</div>
          </div>
        </div>
        <div class="space-y-3">
          {[
            { label: "Signal-matched prospects / week", value: "80-120" },
            { label: "ICP match accuracy", value: "94%" },
            { label: "Enrichment coverage", value: "97%" },
          ].map((row) => (
            <div class="flex items-center justify-between rounded-lg border border-[color:var(--color-border)] px-3 py-2.5">
              <span class="text-[13px] text-[color:var(--color-ink-secondary)]">{row.label}</span>
              <span class="font-mono text-[14px] font-semibold text-teal-600">{row.value}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Social Listening Coverage -->
      <div class="rounded-2xl border border-[color:var(--color-border)] bg-white p-6 transition-all duration-300 hover:shadow-md">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-indigo-50">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-600">
              <path d="M12 20h.01"/><path d="M8.5 16.5a5 5 0 017 0"/><path d="M5 13a10 10 0 0114 0"/><path d="M1.5 9.5a15 15 0 0121 0"/>
            </svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-[color:var(--color-ink-strong)]">Social Listening Agents</div>
            <div class="text-[12px] text-[color:var(--color-ink-muted)]">Always-on signal detection</div>
          </div>
        </div>
        <div class="space-y-3">
          {[
            { label: "Platforms monitored", value: "5+" },
            { label: "Signal types tracked", value: "20+" },
            { label: "Monitoring uptime", value: "99.9%" },
          ].map((row) => (
            <div class="flex items-center justify-between rounded-lg border border-[color:var(--color-border)] px-3 py-2.5">
              <span class="text-[13px] text-[color:var(--color-ink-secondary)]">{row.label}</span>
              <span class="font-mono text-[14px] font-semibold text-indigo-600">{row.value}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Pipeline Impact -->
      <div class="rounded-2xl border border-[color:var(--color-border)] bg-white p-6 transition-all duration-300 hover:shadow-md">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-rose-50">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-rose-600">
              <line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>
            </svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-[color:var(--color-ink-strong)]">Pipeline Impact</div>
            <div class="text-[12px] text-[color:var(--color-ink-muted)]">Revenue metrics</div>
          </div>
        </div>
        <div class="space-y-3">
          {[
            { label: "Cost per qualified meeting", value: "$12" },
            { label: "Meeting-to-opportunity rate", value: "55%" },
            { label: "Pipeline lift vs cold outbound", value: "3-5x" },
          ].map((row) => (
            <div class="flex items-center justify-between rounded-lg border border-[color:var(--color-border)] px-3 py-2.5">
              <span class="text-[13px] text-[color:var(--color-ink-secondary)]">{row.label}</span>
              <span class="font-mono text-[14px] font-semibold text-rose-600">{row.value}</span>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Comparison bar -->
    <div class="rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface-soft)] p-6 sm:p-8" data-reveal>
      <div class="mb-6 text-center">
        <h3 class="font-display text-lg font-medium sm:text-xl tracking-tight">Typpout vs. Traditional Outbound</h3>
        <p class="mt-1 text-sm text-[color:var(--color-ink-secondary)]">Based on aggregated data from 1.2M+ outreach events</p>
      </div>
      <div class="space-y-4">
        {[
          { label: "Reply Rate", typpout: "47%", traditional: "1-5%", typpoutWidth: "94", tradWidth: "10" },
          { label: "Cost per Meeting", typpout: "$12", traditional: "$180+", typpoutWidth: "12", tradWidth: "90" },
          { label: "Time to First Meeting", typpout: "3 days", traditional: "18 days", typpoutWidth: "17", tradWidth: "100" },
          { label: "Meetings per Month", typpout: "25+", traditional: "6-8", typpoutWidth: "100", tradWidth: "32" },
        ].map((row) => (
          <div class="grid grid-cols-1 gap-2 sm:grid-cols-[140px_1fr_1fr]">
            <div class="text-sm font-medium text-[color:var(--color-ink-strong)] sm:py-2">{row.label}</div>
            <div class="flex items-center gap-3">
              <div class="h-8 rounded-lg bg-[color:var(--color-brand)] flex items-center px-3 transition-all duration-500" style={`width: ${row.typpoutWidth}%`}>
                <span class="text-[12px] font-semibold text-white whitespace-nowrap">{row.typpout}</span>
              </div>
              <span class="text-[11px] font-medium text-[color:var(--color-brand-on-light)] whitespace-nowrap">Typpout</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="h-8 rounded-lg bg-[color:var(--color-ink-muted)]/30 flex items-center px-3 transition-all duration-500" style={`width: ${row.tradWidth}%`}>
                <span class="text-[12px] font-medium text-[color:var(--color-ink-secondary)] whitespace-nowrap">{row.traditional}</span>
              </div>
              <span class="text-[11px] text-[color:var(--color-ink-muted)] whitespace-nowrap">Cold outbound</span>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const startCountUp = (el: HTMLElement) => {
    const targetStr = el.dataset.countupTarget || "";
    const targetNum = parseFloat(targetStr.replace(/[^0-9.]/g, ""));
    if (isNaN(targetNum)) return;

    const prefix = targetStr.match(/^[^0-9.]+/)?.[0] || "";
    const suffix = targetStr.match(/[^0-9.]+$/)?.[0] || "";
    const hasComma = targetStr.includes(",");

    const duration = 1200;
    const startTime = performance.now();

    const step = (currentTime: number) => {
      const progress = Math.min((currentTime - startTime) / duration, 1);
      const easeProgress = 1 - Math.pow(1 - progress, 4);
      const currentVal = easeProgress * targetNum;

      let formattedVal = "";
      if (targetStr.includes(".")) {
        formattedVal = currentVal.toFixed(1);
      } else {
        const intVal = Math.floor(currentVal);
        formattedVal = hasComma ? intVal.toLocaleString() : intVal.toString();
      }

      el.textContent = `${prefix}${formattedVal}${suffix}`;

      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        el.textContent = targetStr;
      }
    };
    requestAnimationFrame(step);
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const targets = entry.target.querySelectorAll("[data-countup-target]");
        targets.forEach((t) => startCountUp(t as HTMLElement));
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll("[data-reveal]").forEach((el) => {
    if (el.querySelector("[data-countup-target]")) {
      observer.observe(el);
    }
  });
</script>
