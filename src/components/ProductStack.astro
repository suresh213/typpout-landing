---
import { SITE } from "../data/site";
---

<section id="features" class="mx-auto w-full max-w-[1280px] border-x border-[color:var(--color-border)]">
  <div class="flex flex-col gap-20 border-b border-[color:var(--color-border)] px-4 py-20 md:px-10 md:py-28">

    <div class="space-y-4 text-center" data-reveal>
      <h2 class="font-display text-2xl font-medium sm:text-3xl lg:text-[40px] tracking-tight">
        The Metrics That Matter
      </h2>
      <p class="mx-auto max-w-lg text-base font-light text-[color:var(--color-ink-secondary)]">
        From signal detection to booked meetings, every step measured. Here's how Typpout impacts your GTM pipeline.
      </p>
    </div>

    <!-- Big metric cards -->
    <div class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-border)] lg:grid-cols-4" data-reveal>
      {[
        {
          stat: "1,284",
          unit: "/day",
          label: "Signals Monitored",
          description: "Intent signals detected daily across LinkedIn, X, and Instagram",
        },
        {
          stat: "47",
          unit: "%",
          label: "Reply Rate",
          description: "On signal-matched outreach vs 1-5% for cold email",
        },
        {
          stat: "25",
          unit: "+",
          label: "Meetings / Month",
          description: "Qualified meetings booked from warm social intent signals",
        },
        {
          stat: "8",
          unit: "s",
          label: "AI Reply Time",
          description: "Average time for AI Reply Agent to respond with a personalised message",
        },
      ].map((m) => (
        <div class="flex flex-col items-center bg-white px-5 py-8 text-center transition-colors hover:bg-[color:var(--color-surface-soft)]">
          <span class="font-display text-3xl font-medium tracking-tight text-[color:var(--color-ink-strong)] sm:text-4xl">{m.stat}<span class="text-[color:var(--color-ink-muted)]">{m.unit}</span></span>
          <span class="mt-2 text-sm font-semibold text-[color:var(--color-ink-strong)]">{m.label}</span>
          <p class="mt-1.5 text-[12px] leading-relaxed text-[color:var(--color-ink-muted)]">{m.description}</p>
        </div>
      ))}
    </div>

    <!-- Detailed metric rows -->
    <div class="grid grid-cols-1 gap-5 lg:grid-cols-3" data-reveal>
      {[
        {
          label: "Prospects Surfaced",
          desc: "ICP-matched leads found",
          rows: [
            { label: "Signal-matched prospects / week", value: "80-120" },
            { label: "ICP match accuracy", value: "94%" },
            { label: "Enrichment coverage", value: "97%" },
          ],
        },
        {
          label: "Social Listening Agents",
          desc: "Always-on signal detection",
          rows: [
            { label: "Platforms monitored", value: "5+" },
            { label: "Signal types tracked", value: "20+" },
            { label: "Monitoring uptime", value: "99.9%" },
          ],
        },
        {
          label: "Pipeline Impact",
          desc: "Revenue metrics",
          rows: [
            { label: "Cost per qualified meeting", value: "$12" },
            { label: "Meeting-to-opportunity rate", value: "55%" },
            { label: "Pipeline lift vs cold outbound", value: "3-5x" },
          ],
        },
      ].map((section) => (
        <div class="rounded-2xl border border-[color:var(--color-border)] bg-white p-6 transition-all duration-300 hover:shadow-sm">
          <div class="mb-5">
            <div class="text-sm font-semibold text-[color:var(--color-ink-strong)]">{section.label}</div>
            <div class="text-[12px] text-[color:var(--color-ink-muted)]">{section.desc}</div>
          </div>
          <div class="space-y-2.5">
            {section.rows.map((row) => (
              <div class="flex items-center justify-between rounded-lg bg-[color:var(--color-surface-soft)] px-3.5 py-2.5">
                <span class="text-[13px] text-[color:var(--color-ink-secondary)]">{row.label}</span>
                <span class="font-mono text-[14px] font-semibold text-[color:var(--color-ink-strong)]">{row.value}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>



  </div>
</section>
