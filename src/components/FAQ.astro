---
interface FAQItem {
  q: string;
  a: string;
}
interface Props {
  items?: FAQItem[];
  title?: string;
  subtitle?: string;
}

const defaultFaqs: FAQItem[] = [
  {
    q: "What is Typpout, in one sentence?",
    a: "Typpout is an AI go-to-market platform that listens to social conversations, finds in-market buyers matching your ICP, and books meetings with personalised AI outreach and instant replies.",
  },
  {
    q: "Which platforms does Typpout listen on?",
    a: "LinkedIn, X (Twitter) and Instagram are supported today, with TikTok, Reddit and YouTube on the roadmap. We track posts, comments, reactions, and DM signals in real time.",
  },
  {
    q: "How is this different from a sales engagement tool like HeyReach or Apollo?",
    a: "Tools like HeyReach automate volume; Typpout automates relevance. We listen for buying intent first, then reach out - so reply rates are 3-5x higher than templated cold outbound.",
  },
  {
    q: "How is Typpout different from Jeeva AI or Orange Slice?",
    a: "Jeeva is great at scaled SDR sequences but doesn't ingest social signals natively. Orange Slice focuses on social CRM. Typpout is the only platform that combines listening, ICP matching, outreach AND instant replying in one stack.",
  },
  {
    q: "Will the AI sound like a bot?",
    a: "No. Typpout drafts messages using the prospect's exact post, role, company, and stage. You can approve every message, or set guardrails and let the agents run. Customers consistently report replies feel hand-written.",
  },
  {
    q: "Is there a free trial?",
    a: "Yes - every plan comes with a 14-day free trial. No credit card required. Cancel anytime.",
  },
  {
    q: "How quickly can I see meetings booked?",
    a: "Most customers book their first qualified meeting within the first week. Our Done-For-You plan guarantees 15 meetings per month.",
  },
  {
    q: "Is my data safe?",
    a: "Yes. All credentials are encrypted at rest, social tokens are stored in a SOC 2 Type II-certified vault, and we never sell or share your data. Read our security page for full details.",
  },
];

const {
  items = defaultFaqs,
  title = "Frequently asked questions",
  subtitle = "Everything you need to know about Typpout, GTM signals, and how the AI agents work.",
} = Astro.props;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<section id="faq" class="mx-auto w-full max-w-[1280px] border-x border-[color:var(--color-border)]">
  <div class="px-5 py-24 sm:px-8 lg:py-32">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_1.5fr] lg:gap-16">
      <div class="lg:sticky lg:top-24 lg:self-start" data-reveal>
        <span class="eyebrow">FAQ</span>
        <h2 class="h-section mt-4">{title}</h2>
        <p class="mt-5 max-w-md text-[17px] leading-relaxed text-[color:var(--color-foreground-secondary)]">
          {subtitle}
        </p>
      </div>

      <div class="divide-y divide-[color:var(--color-border)] border-y border-[color:var(--color-border)]" data-reveal>
        {items.map((f, i) => (
          <details class="group py-5" name="faq" open={i === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-6">
              <span class="text-[18px] font-medium text-[color:var(--color-foreground)]">{f.q}</span>
              <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full border border-[color:var(--color-border)] transition group-open:rotate-45">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </span>
            </summary>
            <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-[color:var(--color-foreground-secondary)]">
              {f.a}
            </p>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
