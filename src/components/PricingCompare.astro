---
const rows = [
  { feature: "Outreach accounts",               solo: "2",     growth: "5",        dfy: "Unlimited" },
  { feature: "Social Listening Agent",           solo: true,    growth: true,       dfy: true },
  { feature: "AI Lead Finder",                   solo: "Basic", growth: "Advanced", dfy: "Custom" },
  { feature: "Hyper-personalised outreach",      solo: false,   growth: true,       dfy: true },
  { feature: "AI Reply Agent (replies / mo)",    solo: "100",   growth: "250",      dfy: "Custom" },
  { feature: "Admin controls and audit logs",    solo: false,   growth: true,       dfy: true },
  { feature: "Priority support",                 solo: false,   growth: true,       dfy: true },
  { feature: "Dedicated onboarding",             solo: false,   growth: false,      dfy: true },
  { feature: "GTM Insights AI powered",          solo: false,   growth: false,      dfy: true },
  { feature: "Guaranteed 15 meetings per month", solo: false,   growth: false,      dfy: true },
] as const;
---

<section aria-label="Compare plans" class="mx-auto w-full max-w-[1280px] border-x border-[color:var(--color-border)] bg-[color:var(--color-surface-soft)]">
  <div class="px-4 py-20 md:px-10 md:py-28">
    <div class="max-w-2xl" data-reveal>
      <h2 class="font-display text-2xl font-medium sm:text-3xl lg:text-[40px] tracking-tight">
        Every plan, side by side
      </h2>
      <p class="mt-3 text-base font-light text-[color:var(--color-ink-secondary)]">
        Pick the right level for where your team is today.
      </p>
    </div>

    <div class="mt-10 overflow-x-auto rounded-2xl border border-[color:var(--color-border)] bg-white" data-reveal>
      <table class="w-full min-w-[640px] border-collapse text-left text-[14px]">
        <thead>
          <tr class="border-b border-[color:var(--color-border)]">
            <th class="w-[40%] p-5 text-[13px] font-medium text-[color:var(--color-ink-secondary)]">Feature</th>
            <th class="p-5 text-center font-display text-base font-medium">Solo</th>
            <th class="p-5 text-center font-display text-base font-medium">
              Growth
              <span class="ml-1 rounded-full bg-[color:var(--color-brand)] px-1.5 py-0.5 align-middle text-[9px] font-semibold uppercase text-white">Popular</span>
            </th>
            <th class="p-5 text-center font-display text-base font-medium">Done For You</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr class="border-b border-[color:var(--color-border)] last:border-0">
              <td class="p-5 text-[13px] font-medium text-[color:var(--color-ink-strong)]">{r.feature}</td>
              {[r.solo, r.growth, r.dfy].map((v, i) => (
                <td class:list={["p-5 text-center", i === 1 ? "bg-[color:var(--color-brand-50)]/40" : ""]}>
                  {v === true && (
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="mx-auto text-[color:var(--color-brand)]" aria-label="Yes">
                      <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  )}
                  {v === false && (
                    <span class="mx-auto block text-center text-[color:var(--color-ink-subtle)]" aria-label="No">x</span>
                  )}
                  {typeof v === "string" && (
                    <span class="text-[13px] font-medium text-[color:var(--color-ink-strong)]">{v}</span>
                  )}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
