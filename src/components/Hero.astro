                  <div class="flex items-center justify-between rounded-xl border border-[color:var(--color-brand-200)] bg-[color:var(--color-brand-50)] px-3 py-2.5">
                    <span class="text-[13px] font-medium text-[color:var(--color-brand-on-light)]">Meeting booked: Wed 3:30 PM</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-[color:var(--color-brand)]"><path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
