---
interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  category?: string;
  readingTime?: string;
  featured?: boolean;
  accent?: "green" | "blue" | "pink" | "yellow";
}

const { href, title, description, pubDate, category, readingTime, featured = false, accent = "green" } = Astro.props;

const accentMap = {
  green: "#e5fbf2",
  blue: "#e7efff",
  pink: "#fdecf8",
  yellow: "#fff7ed",
} as const;

const dateStr = pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---

<a
  href={href}
  class:list={[
    "group relative flex flex-col overflow-hidden rounded-3xl border border-[color:var(--color-border)] bg-white transition hover:-translate-y-0.5 hover:shadow-[0_20px_40px_-25px_rgba(0,0,0,0.18)]",
    featured && "md:col-span-2 md:flex-row",
  ]}
>
  <div
    class:list={[
      "shrink-0 p-6",
      featured ? "md:w-1/2" : "h-44 sm:h-52",
    ]}
    style={`background:${accentMap[accent]}`}
  >
    <div class="flex h-full flex-col justify-between">
      <div class="flex items-center gap-2 text-[12px] font-medium uppercase tracking-[0.14em]">
        {category && <span>{category}</span>}
        {readingTime && (
          <>
            <span class="h-1 w-1 rounded-full bg-current opacity-60"></span>
            <span>{readingTime}</span>
          </>
        )}
      </div>
      <span class="font-display text-2xl opacity-70">Typpout</span>
    </div>
  </div>

  <div class="flex flex-1 flex-col gap-3 p-7">
    <h3 class="h-card text-[20px] leading-[1.3] group-hover:underline underline-offset-4 decoration-2 decoration-[color:var(--color-brand)] sm:text-[22px]">
      {title}
    </h3>
    <p class="line-clamp-3 text-[14px] leading-relaxed text-[color:var(--color-foreground-secondary)]">
      {description}
    </p>
    <div class="mt-auto flex items-center justify-between text-[13px] text-[color:var(--color-foreground-secondary)]">
      <time datetime={pubDate.toISOString()}>{dateStr}</time>
      <span class="inline-flex items-center gap-1">
        Read
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
  </div>
</a>
